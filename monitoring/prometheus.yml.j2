global:
  scrape_interval: 15s
  evaluation_interval: 15s

scrape_configs:

  - job_name: 'user-service'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets:
{% for host in groups['user_servers'] %}
          - '{{ hostvars[host]["private_ip_address"] }}:8081'
{% endfor %}

  - job_name: 'payment-service'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets:
{% for host in groups['payment_servers'] %}
          - '{{ hostvars[host]["private_ip_address"] }}:8082'
{% endfor %}

  - job_name: 'order-service'
    metrics_path: '/actuator/prometheus'
    static_configs:
      - targets:
{% for host in groups['order_servers'] %}
          - '{{ hostvars[host]["private_ip_address"] }}:8083'
{% endfor %}
